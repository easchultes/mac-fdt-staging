sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  prov:wasAttributedTo rdfs:label "is attributed to" .
  
  sub:agent a nt:AgentPlaceholder;
    nt:hasDefaultValue nt:CREATOR .
  
  sub:assertion a nt:ProvenanceTemplate;
    rdfs:label "Attributed to myself/others";
    nt:hasStatement sub:st1 .
  
  sub:st1 a nt:RepeatableStatement;
    rdf:object sub:agent;
    rdf:predicate prov:wasAttributedTo;
    rdf:subject nt:ASSERTION .
}

sub:provenance {
