    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:Epsilon-RBD-Variant a <https://w3id.org/fdof/ontology#FAIRDigitalObject>, mac:SpikeRBDVariant ;
    <https://w3id.org/fdof/ontology#hasMetadata> this: ;
    rdfs:label "Spike RBD Variant Epsilon (L120R)" ;
    rdfs:comment "SARS-CoV-2 Spike RBD variant Epsilon, carrying the L120R substitution (corresponding to L452R in the full Spike numbering — Epsilon's canonical defining mutation). Pango lineage B.1.427 + B.1.429 (composite). RBD anchor FDO for the MAC FAIR Digital Twin observation cluster — all Type 2-8 observation FDOs of this variant link back here via mac:isObservationOf." ;
    dct:creator orcid:0000-0001-8888-635X ;
    <https://www.w3.org/ns/dcat#contactPoint> "e.a.schultes@lacdr.leidenuniv.nl" ;
    dct:publisher <https://ror.org/027bh9e22> ;
    dct:isPartOf <https://w3id.org/np/RAFPOe4OIl_urs-U_7-FostjzcUo8ra6LasfSvGplOvto/StayAhead-Project> ;
    mac:hasWHOVariantName "Epsilon" ;
    mac:hasPangoLineage "B.1.427 + B.1.429" ;
    mac:hasGISAIDSeqId "L452R" ;
    mac:hasMACSeqId "L120R" ;
    mac:hasParentProtein <https://www.uniprot.org/uniprot/P0DTC2> ;
    mac:hasRBDSequence "TNLCPFGEVFNATRFASVYAWNRKRISNCVADYSVLYNSASFSTFKCYGVSPTKLNDLCFTNVYADSFVIRGDEVRQIAPGQTGKIADYNYKLPDDFTGCVIAWNSNNLDSKVGGNYNYRYRLFRKSNLKPFERDISTEIYQAGSTPCNGVEGFNCYFPLQSYGFQPTNGVGYQPYRVVVLSFELLHAPATVCGP" ;
    mac:hasGISAIDAccession "EPI_ISL_2295356" ;
    dct:references <https://doi.org/10.3389/fbinf.2025.1634111> ;
    dct:source <https://doi.org/10.71728/hw56-vj34> .

  this: <https://w3id.org/fdof/ontology#materializes> sub:Epsilon-RBD-Variant ;
    <https://w3id.org/fdof/ontology#hasEncodingFormat> <https://www.iana.org/assignments/media-types/application/trig> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    <https://www.w3.org/ns/dcat#accessURL> this: .
}

