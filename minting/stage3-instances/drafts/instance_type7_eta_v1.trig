sub:Head {
  this: a np:Nanopublication ;
    np:hasAssertion sub:assertion ;
    np:hasProvenance sub:provenance ;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  sub:Eta-DMS a <https://w3id.org/fdof/ontology#FAIRDigitalObject>, mac:ExperimentalDMSObservation ;
    <https://w3id.org/fdof/ontology#hasMetadata> this: ;
    rdfs:label "Eta DMS observation — Bloom Lab (bind=9.01256, expr=10.21898)" ;
    rdfs:comment "Deep mutational scanning measurements (Bloom Lab) for SARS-CoV-2 Spike RBD variant Eta (E152K). Six values: bind=9.01256, delta_bind=0.24095, expr=10.21898, delta_expr=0.03311, confidence_bind=0.0722604927671021, confidence_expr=0.0697838486111459. All unitless." ;
    dct:creator orcid:0000-0001-8888-635X ;
    <https://www.w3.org/ns/dcat#contactPoint> "e.a.schultes@lacdr.leidenuniv.nl" ;
    dct:publisher <https://ror.org/027bh9e22> ;
    dct:isPartOf <https://w3id.org/np/RAFPOe4OIl_urs-U_7-FostjzcUo8ra6LasfSvGplOvto/StayAhead-Project> ;
    mac:isObservationOf <https://w3id.org/np/RAikllrKWQoo81RYYvGJjWfzE0QiGrLquMMIwDD6xem2s/Eta-RBD-Variant> ;
    mac:hasExperimentalMethod <https://w3id.org/np/RA0Bz7doV8fCSO9lEmpbtNTOnMu5lB3jVudjo-tD0T_Q0/BloomLab-DMS-Method> ;
    mac:hasBind 9.01256 ;
    mac:hasDeltaBind 0.24095 ;
    mac:hasExpr 10.21898 ;
    mac:hasDeltaExpr 0.03311 ;
    mac:hasConfidenceBind 0.0722604927671021 ;
    mac:hasConfidenceExpr 0.0697838486111459 .

  this: <https://w3id.org/fdof/ontology#materializes> sub:Eta-DMS ;
    <https://w3id.org/fdof/ontology#hasEncodingFormat> <https://www.iana.org/assignments/media-types/application/trig> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    <https://www.w3.org/ns/dcat#accessURL> this: .
}

