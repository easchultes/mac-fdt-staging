sub:assertion {
  mac:hasDeltaExpr a owl:DatatypeProperty;
    dct:partOf <https://w3id.org/spaces/mac/r/ontology/MAC-Ontology>;
    rdfs:comment "Asserts the change in expression level for this variant relative to the wild-type reference, computed as Δ(log MFI).";
    rdfs:domain mac:ExperimentalDMSObservation;
    rdfs:label "has delta_expr (change in expression level)";
    rdfs:range xsd:decimal .
}

