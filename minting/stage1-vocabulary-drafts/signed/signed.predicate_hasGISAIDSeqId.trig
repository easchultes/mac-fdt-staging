sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasGISAIDSeqId a owl:DatatypeProperty;
    dct:partOf <https://w3id.org/spaces/mac/r/ontology/MAC-Ontology>;
    rdfs:comment "Asserts the canonical amino-acid substitution notation, referenced to the full-length SARS-CoV-2 Spike protein numbering, that identifies the defining mutation of this variant as catalogued in GISAID surveillance records.";
    rdfs:domain mac:SpikeRBDVariant;
    rdfs:label "has GISAID seq_id (full Spike mutation notation)";
    rdfs:range xsd:string .
}

sub:provenance {
  sub:assertion dct:created "2026-05-22"^^xsd:date;
    prov:wasAttributedTo orcid:0000-0001-8888-635X .
}

