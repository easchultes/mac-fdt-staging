sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasWHOVariantName a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the World Health Organization-assigned label for the SARS-CoV-2 lineage to which this RBD variant belongs. The WHO scheme uses Greek-letter labels (Alpha, Beta, …, Omicron) for lineages designated as Variant of Concern, Variant of Interest, or Variant Under Monitoring.";
    rdfs:domain mac:SpikeRBDVariant;
    rdfs:label "has WHO variant name";
    rdfs:range xsd:string .
}

sub:provenance {
  sub:assertion dct:created "2026-05-22"^^xsd:date;
    prov:wasAttributedTo orcid:0000-0001-8888-635X .
}

sub:pubinfo {
