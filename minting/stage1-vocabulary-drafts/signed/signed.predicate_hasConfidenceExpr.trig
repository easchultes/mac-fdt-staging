sub:assertion {
  mac:hasConfidenceExpr a owl:DatatypeProperty;
    dct:partOf <https://w3id.org/spaces/mac/r/ontology/MAC-Ontology>;
    rdfs:comment "Asserts the confidence score associated with the expression level measurement, as reported by the deep mutational scanning analysis pipeline.";
