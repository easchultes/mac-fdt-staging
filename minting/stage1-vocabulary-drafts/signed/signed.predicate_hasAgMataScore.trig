sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasAgMataScore a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the AgMata aggregation propensity score computed for this variant's sequence by the Bio2Byte toolkit, indicating predicted tendency to form protein aggregates.";
    rdfs:domain mac:ComputationalPredictionAgMata;
    rdfs:label "has AgMata score (aggregation propensity)";
    rdfs:range xsd:decimal .
}

sub:provenance {
