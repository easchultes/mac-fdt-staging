sub:assertion {
  mac:hasExperimentalMethod a owl:ObjectProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the experimental method through which the measurements reported in this observation were obtained.";
    rdfs:domain mac:ExperimentalObservation;
    rdfs:label "has experimental method";
    rdfs:range mac:ExperimentalMethod .
}

