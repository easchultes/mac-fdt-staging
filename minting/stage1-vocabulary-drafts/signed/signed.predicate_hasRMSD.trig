sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasRMSD a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the Root Mean Square Deviation between the predicted structure of this variant's RBD and a reference structure, measured as the average distance between corresponding atoms after optimal superposition.";
    rdfs:domain mac:ComputationalPredictionRMSD;
    rdfs:label "has RMSD (Root Mean Square Deviation)";
    rdfs:range xsd:decimal .
}

sub:provenance {
