sub:assertion {
  mac:hasSASA a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the Solvent Accessible Surface Area of the predicted structure of this variant's RBD, computed as the surface area accessible to a standard solvent probe.";
    rdfs:domain mac:ComputationalPredictionSASA;
    rdfs:label "has SASA (Solvent Accessible Surface Area)";
    rdfs:range xsd:decimal .
}

