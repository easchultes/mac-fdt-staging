}

sub:assertion {
  mac:hasRBDSequence a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the complete amino-acid sequence of this RBD variant in one-letter code, 195 residues, corresponding to UniProt P0DTC2 positions 331–525 with the variant-defining substitution(s) applied.";
