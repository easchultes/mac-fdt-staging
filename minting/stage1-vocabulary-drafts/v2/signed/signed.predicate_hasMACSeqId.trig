sub:Head {
  this: a np:Nanopublication;
    np:hasAssertion sub:assertion;
    np:hasProvenance sub:provenance;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasMACSeqId a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the amino-acid substitution notation, referenced to the 195-residue Spike Receptor Binding Domain (RBD; UniProt P0DTC2 positions 331–525), that identifies the defining mutation of this variant in the MAC StayAhead RBD-focused pipelines. Differs from `mac:hasGISAIDSeqId` only in the residue numbering reference frame.";
    rdfs:domain mac:SpikeRBDVariant;
    rdfs:label "has MAC seq_id (RBD mutation notation)";
    rdfs:range xsd:string .
}

sub:provenance {
  sub:assertion dct:created "2026-05-22"^^xsd:date;
    prov:wasAttributedTo orcid:0000-0001-8888-635X .
}

