sub:assertion {
  mac:hasExpr a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the protein expression level measurement for this variant, reported as the logarithm of the mean fluorescence intensity (log MFI) from the deep mutational scanning assay.";
    rdfs:domain mac:ExperimentalDMSObservation;
    rdfs:label "has expr (expression level)";
    rdfs:range xsd:decimal .
}

