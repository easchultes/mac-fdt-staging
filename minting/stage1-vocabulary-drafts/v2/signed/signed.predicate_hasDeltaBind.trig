sub:assertion {
  mac:hasDeltaBind a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the change in binding affinity for this variant relative to the wild-type reference, computed as Δ(−log K_D). Positive values indicate stronger binding than wild-type.";
    rdfs:domain mac:ExperimentalDMSObservation;
    rdfs:label "has delta_bind (change in binding affinity)";
    rdfs:range xsd:decimal .
}

