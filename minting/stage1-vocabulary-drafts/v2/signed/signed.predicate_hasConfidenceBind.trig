sub:assertion {
  mac:hasConfidenceBind a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the confidence score associated with the binding affinity measurement, as reported by the deep mutational scanning analysis pipeline. Higher values indicate higher reliability of the binding measurement.";
    rdfs:domain mac:ExperimentalDMSObservation;
    rdfs:label "has confidence_bind (binding confidence score)";
    rdfs:range xsd:decimal .
}

