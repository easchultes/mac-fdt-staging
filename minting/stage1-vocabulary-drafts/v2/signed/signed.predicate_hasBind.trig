sub:assertion {
  mac:hasBind a owl:DatatypeProperty;
    dct:partOf mac:MAC-Ontology;
    rdfs:comment "Asserts the binding affinity measurement for this variant's RBD interaction with its receptor (typically ACE2), reported on a logarithmic scale as −log(K_D). Higher values indicate stronger binding.";
    rdfs:domain mac:ExperimentalDMSObservation;
    rdfs:label "has bind (binding affinity)";
    rdfs:range xsd:decimal .
}

sub:provenance {
