@prefix this: <http://purl.org/nanopub/temp/np001/> .
@prefix sub: <http://purl.org/nanopub/temp/np001/> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix orcid: <https://orcid.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix mac: <https://w3id.org/spaces/mac/r/ontology/> .

sub:Head {
  this: a np:Nanopublication ;
    np:hasAssertion sub:assertion ;
    np:hasProvenance sub:provenance ;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasGISAIDSeqId a owl:DatatypeProperty ;
    rdfs:label "has GISAID seq_id (full Spike mutation notation)" ;
    rdfs:comment """Asserts the canonical amino-acid substitution notation, referenced to the full-length SARS-CoV-2 Spike protein numbering, that identifies the defining mutation of this variant as catalogued in GISAID surveillance records.""" ;
    rdfs:domain mac:SpikeRBDVariant ;
    rdfs:range xsd:string ;
    dct:partOf <https://w3id.org/spaces/mac/r/ontology/MAC-Ontology> .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo <https://orcid.org/0000-0001-8888-635X> ;
    dct:created "2026-05-22"^^xsd:date .
}

sub:pubinfo {
  this: dct:created "2026-05-26T21:47:42Z"^^xsd:dateTime ;
    dct:creator <https://orcid.org/0000-0001-8888-635X> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:label "Vocabulary term: mac:hasGISAIDSeqId" ;
    npx:introduces mac:hasGISAIDSeqId ;
    npx:supersedes <https://w3id.org/np/RA7fIFybLghl4Pedlk7AQRluSoTceFAHvmE1sc5yubKYk> .
}
