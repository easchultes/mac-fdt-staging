@prefix this: <http://purl.org/nanopub/temp/np001/> .
@prefix sub: <http://purl.org/nanopub/temp/np001/> .
@prefix np: <http://www.nanopub.org/nschema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix npx: <http://purl.org/nanopub/x/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix orcid: <https://orcid.org/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix mac: <https://w3id.org/spaces/mac/r/ontology/> .

sub:Head {
  this: a np:Nanopublication ;
    np:hasAssertion sub:assertion ;
    np:hasProvenance sub:provenance ;
    np:hasPublicationInfo sub:pubinfo .
}

sub:assertion {
  mac:hasWHOClassification a owl:ObjectProperty ;
    rdfs:label "has WHO variant classification" ;
    rdfs:comment """Asserts the World Health Organization risk classification assigned to this variant at a given point in time: Variant of Concern (VOC), Variant of Interest (VOI), or Variant Under Monitoring (VUM). Time-stamped because designation status changes over time.""" ;
    rdfs:domain mac:WHOVariantClassification ;
    rdfs:range mac:WHODesignation ;
    dct:partOf <https://w3id.org/spaces/mac/r/ontology/MAC-Ontology> .
}

sub:provenance {
  sub:assertion prov:wasAttributedTo <https://orcid.org/0000-0001-8888-635X> ;
    dct:created "2026-05-22"^^xsd:date .
}

sub:pubinfo {
  this: dct:created "2026-05-26T21:47:42Z"^^xsd:dateTime ;
    dct:creator <https://orcid.org/0000-0001-8888-635X> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:label "Vocabulary term: mac:hasWHOClassification" ;
    npx:introduces mac:hasWHOClassification ;
    npx:supersedes <https://w3id.org/np/RAfMm-QcnxukXutDQZRr8-5-_j7aElaMyeydHKhpPQJg8> .
}
